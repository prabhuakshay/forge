# forge has no required runtime environment configuration.
# This file exists to satisfy the scaffolding check in /forge:audit.

# Optional: override the per-step gate subprocess timeout (seconds, default 600).
# Raise it for projects whose test suite legitimately runs long.
FORGE_GATE_TIMEOUT=600

# Optional: override the default coverage floor the check gate enforces (percent,
# default 80). A project's own [tool.coverage.report] fail_under still wins.
FORGE_COVERAGE_FLOOR=80

# Optional: when truthy (1/true/yes/on), make high-severity bandit code findings
# block the audit gate instead of being advisory warnings. Default off.
FORGE_SECURITY_STRICT=0
