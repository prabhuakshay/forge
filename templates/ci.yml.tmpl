# CI mirrors the local forge gates so a green PR means the same thing a green
# /forge:check + /forge:audit means locally. Keep the Python version in sync with
# pyproject's requires-python (/forge:audit checks this agreement).
name: ci

on:
  push:
    branches: [main]
  pull_request:

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4

      - name: Install uv
        uses: astral-sh/setup-uv@v3
        with:
          python-version: "{{PYTHON_VERSION}}"

      - name: Sync dependencies
        run: uv sync --all-extras

      - name: Lint & format check
        run: |
          uv run ruff check .
          uv run ruff format --check .

      - name: Type check
        run: uv run mypy .

      - name: Tests + coverage
        run: uv run pytest

      - name: Config sync (.env.example)
        run: python3 scripts/check_env_sync.py
