# Single source of truth for this project's identity, dependencies, and tooling.
# /forge:audit checks that the versions declared here agree with CI and the
# toolchain config, so keep this file authoritative.
[project]
name = "{{PROJECT_NAME}}"
version = "0.1.0"
description = "{{DESCRIPTION}}"
readme = "README.md"
requires-python = ">={{PYTHON_VERSION}}"
license = { text = "{{LICENSE}}" }
authors = [{ name = "{{AUTHOR}}" }]
dependencies = []

[project.optional-dependencies]
# Installed in dev/CI but not shipped to consumers.
dev = [
  "ruff>=0.6",
  "mypy>=1.11",
  "pytest>=8",
  "pytest-cov>=5",
  "prek>=0.0.1",
]

[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[tool.hatch.build.targets.wheel]
packages = ["src/{{PACKAGE}}"]

# --- ruff: lint + format (replaces black, isort, flake8, pyupgrade) ----------
[tool.ruff]
target-version = "py{{PYTHON_VERSION_NODOT}}"
line-length = 88
src = ["src", "tests"]

[tool.ruff.lint]
# Balanced rule set: correctness + common bugs + docstring presence on public API.
select = [
  "E", "F", "W",   # pyflakes / pycodestyle
  "I",             # import sorting
  "UP",            # pyupgrade
  "B",             # bugbear
  "SIM",           # simplify
  "D",             # pydocstyle (docstring presence/format)
]
ignore = [
  "D203", "D213",  # conflicting docstring rules; pick the other of each pair
]

[tool.ruff.lint.pydocstyle]
convention = "google"

[tool.ruff.lint.per-file-ignores]
# Tests don't need public-API docstrings.
"tests/**" = ["D"]

# --- mypy: balanced static typing -------------------------------------------
[tool.mypy]
python_version = "{{PYTHON_VERSION}}"
# Require types on your own code...
disallow_untyped_defs = true
warn_return_any = true
warn_unused_ignores = true
warn_redundant_casts = true
# ...but don't drown in third-party libs that ship no stubs.
ignore_missing_imports = true

# --- pytest + coverage ------------------------------------------------------
[tool.pytest.ini_options]
testpaths = ["tests"]
addopts = "--cov={{PACKAGE}} --cov-report=term-missing"

[tool.coverage.report]
# The "balanced" floor. Raise it as the project matures.
fail_under = 80
show_missing = true
