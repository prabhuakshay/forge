version: '3.8'

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile
    container_name: {{PACKAGE}}
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      - PYTHONUNBUFFERED=1
    env_file:
      - .env
    healthcheck:
      test: ["CMD", "python", "-c", "import {{PACKAGE}}; print('ok')"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 10s
