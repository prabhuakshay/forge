version: '3.8'

services:
  app:
    build:
      context: .
      dockerfile: Dockerfile.dev
    container_name: {{PACKAGE}}-dev
    volumes:
      - .:/app
      - /app/.venv
      - /app/.pytest_cache
      - /app/.ruff_cache
      - /app/.mypy_cache
    ports:
      - "8000:8000"
    environment:
      - PYTHONUNBUFFERED=1
    env_file:
      - .env
    stdin_open: true
    tty: true
